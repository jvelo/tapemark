{
  "name": "@jvelo/tapemark",
  "version": "0.7.0",
  "type": "module",
  "description": "Self-contained admin UI for SQLite — framework-agnostic core (router, schema introspection, CRUD, server-rendered Preact UI).",
  "keywords": [
    "sqlite",
    "admin",
    "admin-panel",
    "database",
    "crud",
    "datasette",
    "preact",
    "server-rendered"
  ],
  "license": "MPL-2.0",
  "homepage": "https://github.com/jvelo/tapemark#readme",
  "bugs": "https://github.com/jvelo/tapemark/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/jvelo/tapemark.git",
    "directory": "packages/core"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "check": "tsc --noEmit -p tsconfig.check.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "hono": ">=4.0.0"
  },
  "devDependencies": {
    "better-sqlite3": "^11.0.0",
    "@types/better-sqlite3": "^7.6.0",
    "@jvelo/tapemark-better-sqlite3": "workspace:*",
    "node-gyp": "^12.2.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^3.0.0",
    "typescript": "^5.7.0"
  }
}
