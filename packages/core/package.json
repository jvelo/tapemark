  },
  "peerDependencies": {
    "hono": ">=4.0.0"
  },
  "devDependencies": {
    "better-sqlite3": "^11.0.0",
    "@types/better-sqlite3": "^7.6.0",
    "@jvelo/tapemark-better-sqlite3": "workspace:*",
    "node-gyp": "^12.2.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^3.0.0",
    "typescript": "^5.7.0"
  }
