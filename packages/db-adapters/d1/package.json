{
  "name": "@jvelo/tapemark-d1",
  "version": "0.8.0",
  "type": "module",
  "description": "Cloudflare D1 database adapter for Tapemark.",
  "keywords": [
    "sqlite",
    "cloudflare",
    "d1",
    "admin",
    "tapemark"
  ],
  "license": "MPL-2.0",
  "homepage": "https://github.com/jvelo/tapemark#readme",
  "bugs": "https://github.com/jvelo/tapemark/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/jvelo/tapemark.git",
    "directory": "packages/db-adapters/d1"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "check": "tsc --noEmit -p tsconfig.check.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@jvelo/tapemark": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^3.0.0",
    "typescript": "^5.7.0"
  }
}
