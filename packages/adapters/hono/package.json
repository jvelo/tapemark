{
  "name": "@jvelo/tapemark-hono",
  "version": "0.6.0",
  "type": "module",
  "description": "Hono adapter for Tapemark — mount the SQLite admin UI as a sub-app (Cloudflare Workers, Node, Bun).",
  "keywords": ["sqlite", "admin", "hono", "cloudflare-workers", "d1", "admin-panel", "tapemark"],
  "license": "MPL-2.0",
  "homepage": "https://github.com/jvelo/tapemark#readme",
  "bugs": "https://github.com/jvelo/tapemark/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/jvelo/tapemark.git",
    "directory": "packages/adapters/hono"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "check": "tsc --noEmit -p tsconfig.check.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@jvelo/tapemark": "workspace:*"
  },
  "peerDependencies": {
    "hono": ">=4.0.0"
  },
  "devDependencies": {
    "hono": "^4.0.0",
    "better-sqlite3": "^11.0.0",
    "@types/better-sqlite3": "^7.6.0",
    "@jvelo/tapemark-better-sqlite3": "workspace:*",
    "node-gyp": "^12.2.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^3.0.0",
    "typescript": "^5.7.0"
  }
}
