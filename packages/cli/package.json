{
  "name": "@jvelo/tapemark-cli",
  "version": "0.7.1",
  "type": "module",
  "description": "Zero-config CLI to browse and edit SQLite databases in a dark, monospace admin UI.",
  "keywords": [
    "sqlite",
    "admin",
    "cli",
    "database",
    "admin-panel",
    "datasette",
    "tapemark"
  ],
  "license": "MPL-2.0",
  "homepage": "https://github.com/jvelo/tapemark#readme",
  "bugs": "https://github.com/jvelo/tapemark/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/jvelo/tapemark.git",
    "directory": "packages/cli"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "bin": {
    "tapemark": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "check": "tsc --noEmit",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@jvelo/tapemark": "workspace:*",
    "@jvelo/tapemark-better-sqlite3": "workspace:*",
    "better-sqlite3": "^11.0.0",
    "citty": "^0.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "node-gyp": "^12.2.0",
    "tsx": "^4.0.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^3.0.0",
    "typescript": "^5.7.0"
  }
}
